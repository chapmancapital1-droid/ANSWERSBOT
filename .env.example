# Copy to .env. NEVER commit .env. Prod uses K8s Secrets/Vault.
NODE_ENV=development
LOG_LEVEL=info

DATABASE_URL=postgres://answerspot:answerspot@localhost:5432/answerspot
REDIS_URL=redis://localhost:6379
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

S3_ENDPOINT=http://localhost:9000
S3_BUCKET=answerspot
S3_KEY=answerspot
S3_SECRET=answerspot123
S3_REGION=us-east-1

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...
STRIPE_TRIAL_DAYS=14
# Comma-separated browser origins for CORS / checkout redirects
WEB_ORIGIN=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001

OPENAI_API_KEY=sk-...
PERPLEXITY_API_KEY=pplx-...
PERPLEXITY_MODEL=sonar
GEMINI_API_KEY=...
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-2.0-flash
SERP_API_KEY=

# auto = use live APIs when keys present, else stub
# stub = always deterministic simulator
# live = require live APIs (falls back to stub per-platform on error)
SCAN_MODE=auto
SCAN_LIVE_DELAY_MS=400
SCAN_SAMPLE_COUNT=3
SCAN_MONTHLY_BUDGET_USD=500

NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
